#!/bin/sh
# Build Filter pre-commit hook — guards the strategic direction (docs/STRATEGY.md).
#
# It does NOT block commits. When a commit touches product code (src/), it surfaces
# the three questions every new feature must answer, so focus drift is caught at the
# moment it happens — not two months later when the product has quietly become a
# diagnostics dashboard again.
#
# Install: `npm install` wires it (via the "prepare" script), or run manually:
#   git config core.hooksPath .githooks

# Only nag on product changes — doc/config-only commits pass silently.
staged_src=$(git diff --cached --name-only --diff-filter=ACMR | grep '^src/' || true)
[ -z "$staged_src" ] && exit 0

printf '\n'
printf '  ┌─ Build Filter ─ Revenue Recovery OS ─ Identify · Fix · Prove ─┐\n'
printf '  │                                                               │\n'
printf '  │  This commit changes product code. Before you ship it, ask:   │\n'
printf '  │                                                               │\n'
printf '  │    1. Does it IDENTIFY a recoverable revenue problem?         │\n'
printf '  │    2. Does it help FIX it?                                    │\n'
printf '  │    3. Does it help PROVE money returned?                      │\n'
printf '  │                                                               │\n'
printf '  │  If the answer is no — it does not get built.                 │\n'
printf '  │  No new dashboards / screens / engines / agents without a     │\n'
printf '  │  demand signal.  See docs/STRATEGY.md and CLAUDE.md.          │\n'
printf '  │                                                               │\n'
printf '  └───────────────────────────────────────────────────────────────┘\n'
printf '\n'

# Reminder only — never blocks the commit.
exit 0
